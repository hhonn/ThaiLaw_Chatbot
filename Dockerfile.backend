FROM python:3.11-slim

WORKDIR /app

# Install system deps for sentence-transformers / chromadb
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Install CPU-only PyTorch first to prevent multi-GB CUDA libraries from being pulled
# (Cloud Run has no GPU; CUDA libs waste ~1.5 GB of RAM at runtime)
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu

# Install remaining Python deps (torch already installed, won't be replaced)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Prevent HuggingFace Hub from going online at container startup.
# Models are pre-baked below; offline mode forces use of local cache only.
# Without this, HF Hub tries to re-download every start, fills the
# container writable layer (~2 GB) and can trigger OOM.
ENV HF_HUB_OFFLINE=1
ENV TRANSFORMERS_OFFLINE=1

# Pre-download embedding + reranker models into the image so there is no
# network download on first container start (avoids cold-start OOM / timeout)
RUN HF_HUB_OFFLINE=0 TRANSFORMERS_OFFLINE=0 python -c "from sentence_transformers import SentenceTransformer, CrossEncoder; SentenceTransformer('BAAI/bge-m3'); CrossEncoder('BAAI/bge-reranker-v2-m3'); print('Models cached.')"

# Copy application code
COPY app/ ./app/
COPY data/ ./data/

ENV PYTHONUNBUFFERED=1
ENV APP_HOST=0.0.0.0
ENV APP_PORT=8000

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "app.api:app", "--host", "0.0.0.0", "--port", "8000"]
