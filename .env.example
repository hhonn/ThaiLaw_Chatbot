# Copy this file to .env and fill in real values

# LLM / Typhoon API
TYPHOON_API_KEY=your-typhoon-api-key

# SMTP for OTP email
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# App runtime
APP_HOST=127.0.0.1
APP_PORT=8000
CHROMA_DIR=data/chroma_unified

# Analytics
ANALYTICS_ADMIN_KEY=change-this-admin-key
ANALYTICS_DB_PATH=data/analytics/usage.sqlite3
OTP_DB_PATH=data/analytics/otp.sqlite3
ANALYTICS_EXPORT_RETENTION_DAYS=30
